# Photo Organizer - Frontend Production Environment Template
# Copy this file to frontend/.env.production and fill in the real backend URL.
# Do NOT commit frontend/.env.production -- it is listed in .gitignore.

# URL the browser uses to reach the backend API.
# For local production (same machine), this is typically the backend host/port.
# For a network-accessible production setup, use the actual host IP or hostname.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001
