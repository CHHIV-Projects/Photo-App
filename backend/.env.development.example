# =============================================================================
# Photo Organizer - Development Environment Template
# =============================================================================
# Copy this file to backend/.env.development for local development overrides.
# Do NOT commit backend/.env.development -- it is listed in .gitignore.
#
# This file is optional. If backend/.env.development does not exist, the
# backend will fall back to backend/.env (legacy behavior).
#
# If you have local secrets (e.g. GOOGLE_MAPS_API_KEY) in backend/.env,
# copy them here when you migrate to the .env.development model.
# =============================================================================

# Runtime profile
APP_RUNTIME_PROFILE=development

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=photo_organizer
POSTGRES_USER=photo_user
POSTGRES_PASSWORD=change_me

# =============================================================================
# Cache (Redis)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Storage Paths
# =============================================================================
# Relative paths are resolved from the backend directory.
# Leave as defaults to use the repo's storage/ folder layout.
DROP_ZONE_PATH=../storage/drop_zone
VAULT_PATH=../storage/vault
QUARANTINE_PATH=../storage/quarantine

# =============================================================================
# Backend Server
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# =============================================================================
# Frontend / CORS
# =============================================================================
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# =============================================================================
# External APIs
# =============================================================================
# Copy from backend/.env or set your own local value.
GOOGLE_MAPS_API_KEY=
