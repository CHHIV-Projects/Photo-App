# =============================================================================
# Photo Organizer - Production Environment Template
# =============================================================================
# Copy this file to backend/.env.production and fill in real values.
# Do NOT commit backend/.env.production -- it is listed in .gitignore.
#
# How to create the production env file:
#   copy backend\.env.production.example backend\.env.production
#   (then edit with your real credentials and paths)
# =============================================================================

# Runtime profile -- must be set here AND externally by the launcher script.
APP_RUNTIME_PROFILE=production

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Live PostgreSQL data stays LOCAL on the Windows app host -- not on NAS.
# See docs/operations/production_bootstrap.md for rationale.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=photo_organizer_prod
POSTGRES_USER=photo_user
POSTGRES_PASSWORD=

# =============================================================================
# Cache (Redis)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================================================
# Storage Paths
# =============================================================================
# Use absolute paths for production.
# NAS paths (vault, exports, backups) use UNC format: \\SERVER\Share\folder
# Local paths (logs, previews, quarantine, thumbnails, review) stay on Windows PC.
#
# Example NAS paths (Synology):
#   VAULT_PATH=\\HENDERSON-NAS\PhotoOrganizer\vault
#   EXPORTS_ICLOUD_PATH=\\HENDERSON-NAS\PhotoOrganizer\exports\icloud
#
# Replace with your actual configured NAS share name and folder structure.

STORAGE_ROOT=
VAULT_PATH=
DROP_ZONE_PATH=
EXPORTS_ICLOUD_PATH=
LOGS_PATH=
REPORTS_PATH=
PREVIEWS_PATH=
QUARANTINE_PATH=
THUMBNAILS_PATH=
REVIEW_PATH=

# =============================================================================
# Backend Server
# =============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001

# =============================================================================
# Frontend / CORS
# =============================================================================
FRONTEND_PORT=3000
# Comma-separated list of allowed CORS origins for the backend.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# External APIs
# =============================================================================
# Copy your key from backend/.env or your secret manager.
GOOGLE_MAPS_API_KEY=
